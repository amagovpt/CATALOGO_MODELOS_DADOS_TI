{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$schemaVersion": "0.1.0",
  "modelTags": "CNMD",
  "$id": "https://example.org/schemas/BuildingRegistration.schema.json",
  "title": "CNMD - BuildingRegistration schema",
  "description": "Schema for the registration of a building.",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/GSMA-Commons"
    },
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/Location-Commons"
    },
    {
      "properties": {
        "address": {
          "type": "object",
          "description": "Property. Address associated with the building.",
          "properties": {
            "addressCountry": {
              "type": "string",
              "description": "Property. Country in which the building is located."
            },
            "addressLocality": {
              "type": "string",
              "minLength": 1,
              "description": "Property. Locality, which must correspond to the municipality."
            },
            "addressRegion": {
              "type": "string",
              "enum": [
                "Norte",
                "Centro",
                "Oeste e Vale do Tejo",
                "Grande Lisboa",
                "Península de Setúbal",
                "Alentejo",
                "Algarve",
                "Região Autónoma dos Açores",
                "Região Autónoma da Madeira"
              ],
              "description": "Property. NUTS 2 region in which the locality is located."
            },
            "district": {
              "type": "string",
              "enum": [
                "Açores",
                "Aveiro",
                "Beja",
                "Braga",
                "Bragança",
                "Castelo Branco",
                "Coimbra",
                "Évora",
                "Faro",
                "Guarda",
                "Madeira",
                "Leiria",
                "Lisboa",
                "Portalegre",
                "Porto",
                "Santarém",
                "Setúbal",
                "Viana do Castelo",
                "Vila Real",
                "Viseu"
              ],
              "description": "Property. Administrative district in which the locality is located."
            },
            "postalCode": {
              "type": "string",
              "description": "Property. Postal code of the address."
            },
            "streetAddress": {
              "type": "string",
              "description": "Property. Street address of the building."
            },
            "streetNr": {
              "type": "string",
              "description": "Property. Street number of the building."
            }
          },
          "required": [
            "addressLocality",
            "addressRegion",
            "district"
          ]
        },
        "type": {
          "type": "string",
          "const": "BuildingRegistration",
          "description": "Property. NGSI entity type. It must be BuildingRegistration."
        },
        "buildingId": {
          "type": "string",
          "description": "Property. Unique identifier of the building within the source system."
        },
        "buildingNumber": {
          "type": "string",
          "description": "Property. Identifier of the building in the property register."
        },
        "dateCreated": {
          "type": "string",
          "format": "date-time",
          "description": "Property. Date and time when the entity was created, in ISO 8601 format."
        },
        "dateModified": {
          "type": "string",
          "format": "date-time",
          "description": "Property. Date and time when the entity was last modified, in ISO 8601 format."
        },
        "cadastreNumber": {
          "type": "string",
          "description": "Property. Property tax registration number."
        },
        "description": {
          "type": "string",
          "description": "Property. Additional textual description of the building."
        },
        "workNumber": {
          "type": "string",
          "description": "Property. Identifier of the building works volume."
        },
        "occupation": {
          "type": "string",
          "enum": [
            "ocupado",
            "partialmente_ocupado",
            "livre"
          ],
          "description": "Property. Occupancy status of the building."
        },
        "ownershipType": {
          "type": "string",
          "enum": [
            "municipal",
            "privado",
            "estatal",
            "principalmente_municipal",
            "principalmente_privado",
            "outro"
          ],
          "description": "Property. Ownership type of the building."
        },
        "propertyNature": {
          "type": "string",
          "enum": [
            "rustico",
            "urbano",
            "misto"
          ],
          "description": "Property. Legal nature of the property."
        },
        "stateOfPreservation": {
          "type": "string",
          "enum": [
            "excelente",
            "bom",
            "suficiente",
            "mau",
            "medíocre"
          ],
          "description": "Property. State of preservation of the building."
        },
        "totalFractions": {
          "type": "integer",
          "minimum": 0,
          "description": "Property. Total number of building fractions."
        },
        "use": {
          "type": "string",
          "enum": [
            "residencial",
            "comercial",
            "uso_misto",
            "industrial",
            "terciário",
            "equipamentos",
            "logística",
            "turismo",
            "produção_agrícola",
            "outros"
          ],
          "description": "Property. Intended use of the building."
        },
        "yearOfConstruction": {
          "type": "integer",
          "minimum": 1,
          "description": "Property. Year in which the building was constructed."
        }
      }
    }
  ],
  "required": [
    "id",
    "type",
    "location",
    "address"
  ]
}
