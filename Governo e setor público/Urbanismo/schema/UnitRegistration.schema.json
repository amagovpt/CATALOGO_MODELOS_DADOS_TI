{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$schemaVersion": "0.1.0",
  "modelTags": "CNMD",
  "$id": "https://example.org/schemas/UnitRegistration.schema.json",
  "title": "CNMD - UnitRegistration schema",
  "description": "Schema for the registration of a building unit or fraction.",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/GSMA-Commons"
    },
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/Location-Commons"
    },
    {
      "properties": {
        "address": {
          "type": "object",
          "description": "Property. Address associated with the building unit.",
          "properties": {
            "addressCountry": {
              "type": "string",
              "description": "Property. Country in which the building unit is located."
            },
            "addressLocality": {
              "type": "string",
              "minLength": 1,
              "description": "Property. Locality, which must correspond to the municipality."
            },
            "addressRegion": {
              "type": "string",
              "enum": [
                "Norte",
                "Centro",
                "Oeste e Vale do Tejo",
                "Grande Lisboa",
                "Península de Setúbal",
                "Alentejo",
                "Algarve",
                "Região Autónoma dos Açores",
                "Região Autónoma da Madeira"
              ],
              "description": "Property. NUTS 2 region in which the locality is located."
            },
            "district": {
              "type": "string",
              "enum": [
                "Açores",
                "Aveiro",
                "Beja",
                "Braga",
                "Bragança",
                "Castelo Branco",
                "Coimbra",
                "Évora",
                "Faro",
                "Guarda",
                "Madeira",
                "Leiria",
                "Lisboa",
                "Portalegre",
                "Porto",
                "Santarém",
                "Setúbal",
                "Viana do Castelo",
                "Vila Real",
                "Viseu"
              ],
              "description": "Property. Administrative district in which the locality is located."
            },
            "postalCode": {
              "type": "string",
              "description": "Property. Postal code of the address."
            },
            "streetAddress": {
              "type": "string",
              "description": "Property. Street address of the building unit."
            },
            "streetNr": {
              "type": "string",
              "description": "Property. Street number of the building unit."
            }
          },
          "required": [
            "addressLocality",
            "addressRegion",
            "district"
          ]
        },
        "type": {
          "type": "string",
          "const": "UnitRegistration",
          "description": "Property. NGSI entity type. It must be UnitRegistration."
        },
        "cadastreNumber": {
          "type": "string",
          "description": "Property. Property tax registration number."
        },
        "dateCreated": {
          "type": "string",
          "format": "date-time",
          "description": "Property. Date and time when the entity was created, in ISO 8601 format."
        },
        "dateModified": {
          "type": "string",
          "format": "date-time",
          "description": "Property. Date and time when the entity was last modified, in ISO 8601 format."
        },
        "description": {
          "type": "string",
          "description": "Property. Additional textual description of the building unit."
        },
        "dwellingType": {
          "type": "string",
          "enum": [
            "T0",
            "T1",
            "T2",
            "T3",
            "T4+"
          ],
          "description": "Property. Dwelling typology, applicable when the unit has residential use."
        },
        "fractionId": {
          "type": "string",
          "description": "Property. Unique identifier of the fraction within the source system."
        },
        "fractionNumber": {
          "type": "string",
          "description": "Property. Identifier of the fraction in the property register."
        },
        "occupation": {
          "type": "string",
          "enum": [
            "ocupado",
            "partialmente_ocupado",
            "livre"
          ],
          "description": "Property. Occupancy status of the building unit."
        },
        "ownershipType": {
          "type": "string",
          "enum": [
            "municipal",
            "privado",
            "estado",
            "outro"
          ],
          "description": "Property. Ownership type of the building unit."
        },
        "refBuilding": {
          "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/EntityIdentifierType",
          "description": "Relationship. URN of the BuildingRegistration entity that contains the unit."
        },
        "use": {
          "type": "string",
          "enum": [
            "residencial",
            "comercial",
            "uso_misto",
            "industrial",
            "terciário",
            "equipamentos",
            "logística",
            "turismo",
            "produção_agrícola",
            "outros"
          ],
          "description": "Property. Intended use of the building unit."
        },
        "stateOfPreservation": {
          "type": "string",
          "enum": [
            "excelente",
            "bom",
            "suficiente",
            "mau",
            "medíocre"
          ],
          "description": "Property. State of preservation of the building unit."
        }
      }
    }
  ],
  "required": [
    "id",
    "type",
    "address",
    "refBuilding"
  ]
}
