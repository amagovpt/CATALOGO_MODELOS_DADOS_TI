{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$schemaVersion": "0.1.0",
  "$id": "https://example.org/schemas/MetadataCatalog/schema.json",
  "title": "ARTE JSON-LD DCAT Catalogue metadata schema",
  "description": "Schema for a JSON-LD DCAT Catalogue metadata document",
  "type": "object",
  "additionalProperties": true,
  "$defs": {
    "uri": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9+.-]*:.+"
    },
    "jsonLdId": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "@id": {
          "$ref": "#/$defs/uri"
        }
      },
      "required": [
        "@id"
      ]
    },
    "languageString": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "@value": {
          "type": "string",
          "minLength": 1
        },
        "@language": {
          "type": "string",
          "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
        }
      },
      "required": [
        "@value",
        "@language"
      ]
    },
    "languageStringValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/languageString"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/languageString"
          },
          "minItems": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "context": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "dcterms": {
          "const": "http://purl.org/dc/terms/"
        },
        "dct": {
          "const": "http://purl.org/dc/terms/"
        },
        "dcat": {
          "enum": [
            "https://www.w3.org/ns/dcat#",
            "http://www.w3.org/ns/dcat#"
          ]
        },
        "foaf": {
          "const": "http://xmlns.com/foaf/0.1/"
        },
        "xsd": {
          "const": "http://www.w3.org/2001/XMLSchema#"
        }
      },
      "required": [
        "dcat",
        "foaf"
      ],
      "anyOf": [
        {
          "required": [
            "dcterms"
          ]
        },
        {
          "required": [
            "dct"
          ]
        }
      ]
    },
    "publisher": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "@type": {
          "enum": [
            "foaf:Organization",
            "foaf:Agent"
          ]
        },
        "foaf:name": {
          "$ref": "#/$defs/languageStringValue"
        },
        "foaf:homepage": {
          "$ref": "#/$defs/jsonLdId"
        }
      },
      "required": [
        "@type",
        "foaf:name"
      ]
    },
    "spatial": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "@type": {
          "enum": [
            "dcterms:Location",
            "dct:Location"
          ]
        },
        "dcterms:title": {
          "$ref": "#/$defs/languageStringValue"
        },
        "dct:title": {
          "$ref": "#/$defs/languageStringValue"
        },
        "dcat:bbox": {
          "type": "string",
          "pattern": "^POLYGON\\(\\(.+\\)\\)$"
        },
        "locn:geometry": {
          "type": "object"
        }
      },
      "required": [
        "@type"
      ],
      "anyOf": [
        {
          "required": [
            "dcterms:title"
          ]
        },
        {
          "required": [
            "dct:title"
          ]
        },
        {
          "required": [
            "locn:geometry"
          ]
        },
        {
          "required": [
            "dcat:bbox"
          ]
        }
      ]
    }
  },
  "properties": {
    "@context": {
      "$ref": "#/$defs/context"
    },
    "@id": {
      "$ref": "#/$defs/uri"
    },
    "@type": {
      "enum": [
        "dcat:Catalog",
        "dcat:Catalogue"
      ]
    },
    "dcterms:title": {
      "$ref": "#/$defs/languageStringValue"
    },
    "dct:title": {
      "$ref": "#/$defs/languageStringValue"
    },
    "dcterms:description": {
      "$ref": "#/$defs/languageStringValue"
    },
    "dct:description": {
      "$ref": "#/$defs/languageStringValue"
    },
    "dcterms:publisher": {
      "$ref": "#/$defs/publisher"
    },
    "dct:publisher": {
      "$ref": "#/$defs/publisher"
    },
    "dcterms:license": {
      "$ref": "#/$defs/jsonLdId"
    },
    "dct:license": {
      "$ref": "#/$defs/jsonLdId"
    },
    "dcterms:spatial": {
      "$ref": "#/$defs/spatial"
    },
    "dct:spatial": {
      "$ref": "#/$defs/spatial"
    }
  },
  "required": [
    "@type"
  ],
  "allOf": [
    {
      "anyOf": [
        {
          "required": [
            "dcterms:title"
          ]
        },
        {
          "required": [
            "dct:title"
          ]
        }
      ]
    },
    {
      "anyOf": [
        {
          "required": [
            "dcterms:description"
          ]
        },
        {
          "required": [
            "dct:description"
          ]
        }
      ]
    },
    {
      "anyOf": [
        {
          "required": [
            "dcterms:publisher"
          ]
        },
        {
          "required": [
            "dct:publisher"
          ]
        }
      ]
    },
    {
      "anyOf": [
        {
          "required": [
            "dcterms:license"
          ]
        },
        {
          "required": [
            "dct:license"
          ]
        }
      ]
    },
    {
      "anyOf": [
        {
          "required": [
            "dcterms:spatial"
          ]
        },
        {
          "required": [
            "dct:spatial"
          ]
        }
      ]
    }
  ]
}
