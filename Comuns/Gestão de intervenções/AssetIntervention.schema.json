{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$schemaVersion": "0.1.0",
  "modelTags": "CNMD",
  "$id": "https://example.org/schemas/AssetIntervention/schema.json",
  "title": "Asset Intervention schema",
  "description": "Schema for an intervention performed on an asset or infrastructure",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/GSMA-Commons"
    },
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/Location-Commons"
    },
    {
      "properties": {
        "address": {
          "type": "object",
          "properties": {
            "addressLocality": {
              "type": "string",
              "minLength": 1,
              "description": "The locality, which must correspond to the municipality"
            },
            "addressRegion": {
              "type": "string",
              "enum": [
                "Norte",
                "Centro",
                "Oeste e Vale do Tejo",
                "Grande Lisboa",
                "Península de Setúbal",
                "Alentejo",
                "Algarve",
                "Região Autónoma dos Açores",
                "Região Autónoma da Madeira"
              ],
              "description": "The NUTS 2 region in which the locality is located"
            },
            "district": {
              "type": "string",
              "enum": [
                "Açores",
                "Aveiro",
                "Beja",
                "Braga",
                "Bragança",
                "Castelo Branco",
                "Coimbra",
                "Évora",
                "Faro",
                "Guarda",
                "Madeira",
                "Leiria",
                "Lisboa",
                "Portalegre",
                "Porto",
                "Santarém",
                "Setúbal",
                "Viana do Castelo",
                "Vila Real",
                "Viseu"
              ],
              "description": "The administrative district in which the locality is located"
            }
          },
          "required": [
            "addressLocality",
            "addressRegion",
            "district"
          ]
        },
        "type": {
          "type": "string",
          "const": "AssetIntervention",
          "description": "Property. NGSI entity type. It has to be AssetIntervention"
        },
        "dateFinished": {
          "type": "string",
          "format": "date-time",
          "description": "Property. Date and time when the intervention was completed, in ISO 8601 format"
        },
        "dateStarted": {
          "type": "string",
          "format": "date-time",
          "description": "Property. Date and time when the intervention started, in ISO 8601 format"
        },
        "completionPercentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Property. Intervention completion percentage"
        },
        "contactPoint": {
          "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/Contact-Commons/properties/contactPoint"
        },
        "contractor": {
          "type": "string",
          "description": "Property. Name of the contractor responsible for the intervention"
        },
        "estimatedDuration": {
          "type": "number",
          "minimum": 0,
          "description": "Property. Estimated duration of the intervention, normally expressed in days"
        },
        "impactLevel": {
          "type": "string",
          "enum": [
            "None",
            "Low",
            "Moderate",
            "High",
            "Severe"
          ],
          "description": "Property. Impact level on the asset's normal activities"
        },
        "infrastructureType": {
          "type": "string",
          "enum": [
            "dam",
            "retainingWall",
            "slope/Embankment",
            "drainageSystem",
            "utilityNetworks",
            "railway",
            "harbor/PortInfrastructure",
            "airportInfrastructure",
            "publicSpaceStructures",
            "slopeStabilizationStructures",
            "pedestrianandCyclingInfrastructure"
          ],
          "description": "Property. Type of infrastructure affected by the intervention"
        },
        "interventionType": {
          "type": "string",
          "enum": [
            "construction",
            "rehabilitation/Renovation",
            "maintenance",
            "inspection/Monitoring",
            "cleaningClearing",
            "demolition/Removal",
            "stabilization/Reinforcement",
            "upgrading/Modernization",
            "emergencyRepair",
            "protectiveWorks",
            "paving/Repaving",
            "landscaping/EnvironmentalIntegration",
            "dredging",
            "coastalProtectionWorks",
            "vegetationandLandManagementInterventions"
          ],
          "description": "Property. Type of intervention performed"
        },
        "inspectionAgent": {
          "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/EntityIdentifierType",
          "description": "Relationship. Organization responsible for inspection"
        },
        "investment": {
          "type": "number",
          "minimum": 0,
          "description": "Property. Financial investment associated with the intervention, normally expressed in euros"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Property. Name of the intervention"
        },
        "priority": {
          "type": "string",
          "enum": [
            "Low",
            "Medium",
            "High"
          ],
          "description": "Property. Priority assigned to the intervention"
        },
        "responsibleAgent": {
          "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/EntityIdentifierType",
          "description": "Relationship. Organization responsible for executing the intervention"
        },
        "responsibleAuthority": {
          "type": "string",
          "description": "Property. Public authority responsible for supervision"
        },
        "seeAlso": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Property. URIs pointing to additional resources about the intervention"
        },
        "status": {
          "type": "string",
          "enum": [
            "Planned",
            "Scheduled",
            "InProgress",
            "Completed",
            "Cancelled"
          ],
          "description": "Property. Current status of the intervention"
        },
        "targetAsset": {
          "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/EntityIdentifierType",
          "description": "Relationship. Asset or infrastructure affected by the intervention"
        },
        "workingDays": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Property. Days of the week on which the intervention takes place"
        },
        "workingHours": {
          "type": "string",
          "description": "Property. Planned daily working hours"
        }
      }
    }
  ],
  "required": [
    "id",
    "type",
    "address",
    "name",
    "location"
  ]
}
