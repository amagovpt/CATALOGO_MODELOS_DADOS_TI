{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$schemaVersion": "0.4.1",
  "modelTags": "",
  "$id": "https://smart-data-models.github.io/dataModel.Weather/WeatherAlert/schema.json",
  "title": "Smart Data Models - Weather Alert data model ",
  "description": "A weather alert generated by a user or device in a given location",
  "allOf": [
    {
      "$ref": "https://smart-data-models.github.io/dataModel.Weather/weather-schema.json#/definitions/Weather-Alert"
    },
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/GSMA-Commons"
    },
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/Location-Commons"
    },
    {
      "type": "object",
      "properties": {
        "address": {
          "type": "object",
          "properties": {
            "addressLocality": {
              "type": "string",
              "minLength": 1,
              "description": "The locality, which must correspond to the municipality"
            },
            "addressRegion": {
              "type": "string",
              "enum": [
                "Norte",
                "Centro",
                "Oeste e Vale do Tejo",
                "Grande Lisboa",
                "Península de Setúbal",
                "Alentejo",
                "Algarve",
                "Região Autónoma dos Açores",
                "Região Autónoma da Madeira"
              ],
              "description": "The NUTS 2 region in which the locality is located"
            },
            "district": {
              "type": "string",
              "enum": [
                "Açores",
                "Aveiro",
                "Beja",
                "Braga",
                "Bragança",
                "Castelo Branco",
                "Coimbra",
                "Évora",
                "Faro",
                "Guarda",
                "Madeira",
                "Leiria",
                "Lisboa",
                "Portalegre",
                "Porto",
                "Santarém",
                "Setúbal",
                "Viana do Castelo",
                "Vila Real",
                "Viseu"
              ],
              "description": "The administrative district in which the locality is located"
            }
          },
          "required": [
            "addressLocality",
            "addressRegion",
            "district"
          ]
        },
        "type": {
          "type": "string",
          "description": "Property. NGSI entity type. It has to be WeatherAlert",
          "enum": [
            "WeatherAlert"
          ]
        },
        "subCategory": {
          "$ref": "https://smart-data-models.github.io/dataModel.Weather/weather-schema.json#/definitions/WeatherAlertCategories"
        }
      }
    }
  ],
  "required": [
    "id",
    "type",
    "address",
    "alertSource",
    "category",
    "subCategory",
    "dateIssued"
  ]
}